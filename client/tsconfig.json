{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["vite/client"],
    "baseUrl": "src",
    "paths": { "@game/*": ["game/*"], "@ui/*": ["ui/*"], "@net/*": ["net/*"] },
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
